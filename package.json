{
  "name": "@mstssk/serve",
  "version": "0.0.5",
  "description": "Minimal static file server for local development",
  "keywords": [
    "dev-server",
    "file-server",
    "serve",
    "static",
    "static-server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mstssk/serve.git"
  },
  "bin": {
    "serve": "bin/serve.mjs"
  },
  "files": [
    "bin",
    "lib"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "example": "node bin/serve.mjs example -p 3000 -H",
    "test": "node --test test/*.test.mjs test/**/*.test.mjs",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  }
}
